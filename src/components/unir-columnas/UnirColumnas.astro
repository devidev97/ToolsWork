        console.error("main: obj debe tener tripulantes.");
        return;
    }

    console.log("═══ PASO 1: Sincronizando datos desde la web ═══");
    const resultado = await sincronizarDatosDesdeWeb(obj);
    if (!resultado) return;

    console.log("\\n═══ PASO 2: Desembarcando tripulantes ═══");
    const primero = obj.tripulantes[0];
    await desembarcarCrewlist({
        fecha: primero.fecha,
        hora: primero.hora,
        minutos: primero.minutos
    });

    console.log("\\n═══ PASO 3: Embarcando tripulantes ═══");
    await embarcarCrewlist(resultado);
}
