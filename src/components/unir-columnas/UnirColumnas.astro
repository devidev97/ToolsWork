---
// UnirColumnas component
---

<div class="flex flex-col items-center min-h-screen bg-[#f4f7f9] pt-[67px] pb-10">
	<!-- Contenedor principal -->
	<div id="input-container" class="w-full max-w-[800px] px-4 pt-4">
		<!-- Fecha y hora -->
		<div class="flex flex-col gap-4 mb-6">
			<div class="flex flex-col w-fit">
				<label for="fecha-input" class="text-sm font-medium text-gray-700 mb-1">Fecha</label>
				<input
					id="fecha-input"
					type="date"
					class="w-fit min-w-[140px] px-3 py-2 text-sm border border-gray-300 rounded-md bg-white focus:outline-none focus:border-gray-400 text-gray-800"
				/>
			</div>
			<div class="flex flex-col w-fit">
				<label for="hora-input" class="text-sm font-medium text-gray-700 mb-1">Hora</label>
				<input
					id="hora-input"
					type="time"
					class="w-fit min-w-[100px] px-3 py-2 text-sm border border-gray-300 rounded-md bg-white focus:outline-none focus:border-gray-400 text-gray-800"
				/>
			</div>
		</div>

		<div class="flex flex-col gap-4 mb-6 w-full">
			<!-- Columna A (nombres) -->
			<div class="flex flex-col w-full">
				<label for="column-a-textarea" class="text-sm font-medium text-gray-700 mb-1">Nombres (una por línea)</label>
				<textarea
					id="column-a-textarea"
					class="w-full p-3 text-base border border-gray-300 rounded-md block resize-y box-border h-[300px] bg-white focus:outline-none focus:border-gray-400 text-gray-800"
					placeholder="Pega aquí la columna de nombres..."
				/>
			</div>
			<!-- Columna B (documentos) -->
			<div class="flex flex-col w-full">
				<label for="column-b-textarea" class="text-sm font-medium text-gray-700 mb-1">Documentos (una por línea)</label>
				<textarea
					id="column-b-textarea"
					class="w-full p-3 text-base border border-gray-300 rounded-md block resize-y box-border h-[300px] bg-white focus:outline-none focus:border-gray-400 text-gray-800"
					placeholder="Pega aquí la columna de documentos..."
				/>
			</div>
		</div>

		<!-- Botón Process -->
		<div id="process-button-container" class="flex justify-center mb-5">
			<button
				id="action-button"
				class="inline-flex items-center px-6 py-2 text-sm font-medium rounded-md text-white bg-[#002B45] focus:outline-none transition-shadow hover:shadow-md"
			>
				Procesar
			</button>
		</div>
	</div>

	<!-- Contenedor para resultados -->
	<div id="results-container" class="w-[90%] max-w-[800px] mx-auto hidden">
		<div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden mb-6">
			<div class="bg-[#002B45] text-white p-3 border-b border-[#003366] flex justify-between items-center">
				<span class="font-medium">Resultado: <span id="total-count">0</span> objetos</span>
				<div class="flex items-center gap-3">
					<button
						id="copy-json-button"
						class="p-1.5 rounded-md hover:bg-white/10 transition-colors text-white focus:outline-none"
						title="Copiar JSON"
					>
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
						</svg>
					</button>
				</div>
			</div>
			<div class="p-4">
				<pre id="output-pre" class="bg-gray-50 p-4 rounded-md overflow-auto text-sm text-gray-800 max-h-[600px] border border-gray-200 whitespace-pre"></pre>
			</div>
		</div>

		<!-- Botón Reiniciar -->
		<div class="flex justify-center">
			<button
				id="reset-button"
				class="inline-flex items-center px-6 py-2 text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none transition-shadow hover:shadow-md"
			>
				Reiniciar
			</button>
		</div>
	</div>

	<!-- Toast de éxito -->
	<div id="toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-gray-800 text-white px-6 py-3 rounded-full shadow-lg transition-all duration-300 opacity-0 pointer-events-none z-[60]">
		Copiado al portapapeles
	</div>

	<!-- Diálogo de alerta personalizado -->
	<div id="alert-overlay" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 hidden">
		<div id="alert-dialog" class="w-full max-w-md bg-white rounded-md overflow-hidden shadow-lg">
			<div class="bg-[#001a33] px-4 py-3 flex items-center justify-between">
				<h3 class="text-base font-medium text-white">Error</h3>
				<button id="alert-close" class="rounded-full p-1 text-white hover:bg-white/10">
					<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</button>
			</div>
			<div class="p-4">
				<p id="alert-message" class="text-sm text-gray-700"></p>
				<div class="mt-4 flex justify-end">
					<button id="alert-ok" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-md text-sm font-medium">Aceptar</button>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const textareaA = document.getElementById('column-a-textarea') as HTMLTextAreaElement;
		const textareaB = document.getElementById('column-b-textarea') as HTMLTextAreaElement;
		const fechaInput = document.getElementById('fecha-input') as HTMLInputElement;
		const horaInput = document.getElementById('hora-input') as HTMLInputElement;
		const actionButton = document.getElementById('action-button') as HTMLButtonElement;
		const copyJsonButton = document.getElementById('copy-json-button') as HTMLButtonElement;
		const resetButton = document.getElementById('reset-button') as HTMLButtonElement;
		const inputContainer = document.getElementById('input-container');
		const resultsContainer = document.getElementById('results-container');
		const outputPre = document.getElementById('output-pre');
		const totalCountSpan = document.getElementById('total-count');
		const alertOverlay = document.getElementById('alert-overlay');
		const alertMessage = document.getElementById('alert-message');
		const alertClose = document.getElementById('alert-close');
		const alertOk = document.getElementById('alert-ok');
		const toast = document.getElementById('toast');

		type Tripulante = { nombre: string; documento: string; fecha: string; hora: string; minutos: string };
		let combinedResult: { tripulantes: Tripulante[] } = { tripulantes: [] };

		const CODIGO_AUTOMATIZACION = `
// ─── UTILIDADES ───────────────────────────────────────────────────

function esperar(ms) {
    return new Promise(r => setTimeout(r, ms));
}

function clickEnZonaAngular(btn) {
    const key = Object.getOwnPropertyNames(btn).find(k => k.includes('zone') && k.includes('click'));
    const tasks = key ? btn[key] : null;
    const zone = tasks && tasks[0] && tasks[0].zone;
    if (zone && typeof zone.run === 'function') {
        zone.run(() => btn.click());
    } else {
        btn.focus();
        const rect = btn.getBoundingClientRect();
        const opts = { bubbles: true, cancelable: true, view: window, clientX: rect.left + rect.width / 2, clientY: rect.top + rect.height / 2 };
        btn.dispatchEvent(new MouseEvent('mousedown', opts));
        btn.dispatchEvent(new MouseEvent('mouseup', opts));
        btn.dispatchEvent(new MouseEvent('click', opts));
    }
}

function escribirBuscador(valor) {
    const input = document.getElementById('crewMemberDetails');
    if (input) {
        input.value = valor;
        input.dispatchEvent(new Event('input', { bubbles: true }));
    }
}

function limpiarBuscador() {
    escribirBuscador('');
}

function resetearSelectores() {
    document.querySelectorAll("select.form-control").forEach(sel => {
        sel.selectedIndex = 0;
        sel.dispatchEvent(new Event("change", { bubbles: true }));
    });
}

function checkFila(fila) {
    const checkboxes = document.querySelectorAll('tbody input[type="checkbox"]');
    const indice = fila - 1;
    const cb = checkboxes[indice];

    if (cb) {
        if (!cb.checked) {
            cb.click();
            cb.checked = true;
            cb.dispatchEvent(new Event('change', { bubbles: true }));
            cb.dispatchEvent(new Event('input', { bubbles: true }));
        }
    } else {
        console.warn(\`No existe la fila \${fila}. Solo hay \${checkboxes.length} disponibles.\`);
    }
}

// ─── PAGINACIÓN ───────────────────────────────────────────────────

function clickPaginaAnterior() {
    const prevLink =
        document.querySelector('.table-pagination-numbers li.pagination-prev a.page-link') ||
        document.querySelector('ul.pagination li.pagination-prev a.page-link') ||
        document.querySelector('.table-pagination-numbers a.page-link');

    if (!prevLink) return false;

    const li = prevLink.closest('li');
    if (li && li.classList.contains('disabled')) return false;

    prevLink.click();
    const active =
        document.querySelector('.table-pagination-numbers ul.pagination li.active a.page-link') ||
        document.querySelector('ul.pagination li.active a.page-link');
    if (!active) return false;
    const num = parseInt(active.textContent.trim(), 10);
    return Number.isNaN(num) ? false : num;
}

function clickPaginaSiguiente() {
    const nextLink =
        document.querySelector('.table-pagination-numbers a[aria-label="Next"]') ||
        document.querySelector('ul.pagination li.pagination-next a.page-link') ||
        Array.from(document.querySelectorAll('.table-pagination-numbers a, .pagination a')).find(el =>
            el.textContent.trim() === '»' && !el.closest('.pagination-prev')
        );

    if (!nextLink) return false;

    const li = nextLink.closest('li');
    if (li && (li.classList.contains('disabled') || nextLink.getAttribute('disabled'))) return false;

    nextLink.click();
    return true;
}

async function irAUltimaPagina() {
    while (clickPaginaSiguiente()) {
        await esperar(2000);
    }
}

// ─── TABLA: LECTURA Y PARSEO ─────────────────────────────────────

const CLAVES_COLUMNAS = ['selected', 'lastName', 'firstName', 'position', 'birthDate', 'nationality', 'documentType', 'documentNumber', 'transportation', 'boardDeboardDate', 'status', 'actions'];

function obtenerCabecerasTabla() {
    const ths = document.querySelectorAll('table.table thead th, table thead th');
    if (!ths.length) return null;
    return Array.from(ths).map(th => {
        const t = th.textContent.trim().toLowerCase().replace(/[^a-z0-9\s]/g, '');
        return t.replace(/\\s+/g, ' ').split(' ').filter(Boolean).map((s, i) => i === 0 ? s : s.charAt(0).toUpperCase() + s.slice(1)).join('');
    });
}

function obtenerClaveCelda(td, indice, cabeceras) {
    const dataTest = td.getAttribute('data-test');
    if (dataTest) return dataTest;
    if (cabeceras && cabeceras[indice]) return cabeceras[indice];
    return CLAVES_COLUMNAS[indice] || \`column\${indice}\`;
}

function extraerFila(fila) {
    const filas = document.querySelectorAll('tbody tr');
    const indice = typeof fila === 'number' ? fila - 1 : fila;
    const tr = typeof fila === 'number' ? filas[indice] : fila;

    if (!tr) return null;

    const cabeceras = obtenerCabecerasTabla();
    const celdas = tr.querySelectorAll('td');
    const obj = {};

    celdas.forEach((td, i) => {
        const clave = obtenerClaveCelda(td, i, cabeceras);
        if (i === 0) {
            const check = td.querySelector('input[type="checkbox"]');
            obj[clave] = check ? check.checked : false;
        } else {
            obj[clave] = td.textContent.trim();
        }
    });

    const idFila = tr.id || tr.getAttribute('id');
    if (idFila) obj.id = idFila;

    return obj;
}

function parsearFechaHoraDeTabla(boardDeboardDate) {
    if (!boardDeboardDate) return null;
    const texto = boardDeboardDate.trim();
    const m = texto.match(/^(\\d{2}\\.\\d{2}\\.\\d{4})\\s+(\\d{1,2}):(\\d{2})$/);
    if (m) {
        return { fecha: m[1], hora: m[2], minutos: m[3] };
    }
    const partes = texto.split(/[\\s]+/);
    const fecha = partes[0] || '';
    const horaParte = partes[1] || '';
    const [hora, minutos] = horaParte.split(':');
    return {
        fecha: fecha,
        hora: hora || '00',
        minutos: minutos || '00'
    };
}

// ─── SELECTORES DE BARCO Y STATUS ────────────────────────────────

async function ajustarSelectoresPorBarco(opciones = {}) {
    const statusTexto = (opciones.statusTexto || 'BOARD').toUpperCase();
    const aplicarFiltro = opciones.aplicarFiltro !== false;

    const tituloElemento = document.querySelector('h1, h3, .protractorPageTitle');
    if (!tituloElemento || !tituloElemento.innerText.includes(' on ')) return false;

    const nombreBarcoDetectado = tituloElemento.innerText.split(' on ').pop().trim();
    const barcoTexto = (opciones.barcoTexto || nombreBarcoDetectado).toUpperCase();
    const selectorBarco = document.querySelector('select[name="transportation"]');
    const selectorStatus = document.querySelector('select[name="status"]');

    if (!selectorBarco || !selectorStatus) return false;

    const opcionBarco = Array.from(selectorBarco.options).find(opt =>
        opt.text.trim().toUpperCase().includes(barcoTexto)
    );
    if (opcionBarco) {
        selectorBarco.value = opcionBarco.value;
        selectorBarco.dispatchEvent(new Event('change', { bubbles: true }));
    }

    const opcionStatus = Array.from(selectorStatus.options).find(opt =>
        opt.text.toUpperCase().includes(statusTexto)
    );
    if (opcionStatus) {
        selectorStatus.value = opcionStatus.value;
        selectorStatus.dispatchEvent(new Event('change', { bubbles: true }));
    }

    limpiarBuscador();

    if (aplicarFiltro) {
        const btnFilter = document.getElementById('filterButton') ||
            Array.from(document.querySelectorAll('button')).find(b =>
                b.innerText.trim() === 'Filter'
            );
        if (btnFilter) {
            btnFilter.click();
            await esperar(2000);
        }
    }

    return true;
}

// ─── SINCRONIZACIÓN POR PÁGINAS (EFICIENTE) ──────────────────────

function sincronizarTripulante(fila, objetoConTripulantes) {
    const tripulanteFila = extraerFila(fila);
    const lista = objetoConTripulantes.tripulantes;
    if (!tripulanteFila || !Array.isArray(lista) || !lista.length) return false;

    const docFila = String(tripulanteFila.documentNumber ?? '').trim().toUpperCase();
    const textoNombreFila = [tripulanteFila.lastName, tripulanteFila.firstName]
        .filter(Boolean)
        .join(' ')
        .toUpperCase();
    const fechaTabla = parsearFechaHoraDeTabla(tripulanteFila.boardDeboardDate);

    function actualizarDatos(tripulante) {
        if (fechaTabla) {
            tripulante.fecha = fechaTabla.fecha;
            tripulante.hora = fechaTabla.hora;
            tripulante.minutos = fechaTabla.minutos;
        }
        if (docFila && (!tripulante.documento || !tripulante.documento.trim())) {
            tripulante.documento = docFila;
        }
        console.log(\`  ✓ \${tripulante.nombre || tripulante.documento} → \${fechaTabla?.fecha || '?'} \${fechaTabla?.hora || '?'}:\${fechaTabla?.minutos || '?'}\`);
    }

    for (const t of lista) {
        const docLista = String(t.documentNumber ?? t.documento ?? '').trim().toUpperCase();
        if (docFila && docLista && docLista === docFila) {
            actualizarDatos(t);
            return true;
        }
    }

    for (const t of lista) {
        const nombre = String(t.nombre ?? [t.lastName, t.firstName].filter(Boolean).join(' ') ?? '').trim();
        if (!nombre) continue;
        const palabras = nombre.split(/\\s+/).filter(Boolean).map(p => p.toUpperCase());
        if (palabras.length && palabras.every(p => textoNombreFila.includes(p))) {
            actualizarDatos(t);
            return true;
        }
    }

    return false;
}

function sincronizarTodasLasFilas(objetoConTripulantes) {
    const filas = document.querySelectorAll('tbody tr');
    let sincronizados = 0;
    let noEncontrados = 0;
    for (let i = 1; i <= filas.length; i++) {
        const ok = sincronizarTripulante(i, objetoConTripulantes);
        if (ok) sincronizados++;
        else noEncontrados++;
    }
    return { sincronizados, noEncontrados };
}

// ═══════════════════════════════════════════════════════════════════
// FUNCIÓN PRINCIPAL 1: SINCRONIZAR DATOS DESDE LA WEB
// ═══════════════════════════════════════════════════════════════════

async function sincronizarDatosDesdeWeb(obj) {
    if (!obj?.tripulantes?.length) {
        console.error('sincronizarDatosDesdeWeb: obj debe tener tripulantes.');
        return null;
    }

    const resultado = {
        tripulantes: obj.tripulantes.map(t => ({ ...t }))
    };

    await ajustarSelectoresPorBarco({ statusTexto: 'BOARD', aplicarFiltro: true });
    limpiarBuscador();
    await irAUltimaPagina();

    let totalSincronizados = 0;
    let totalNoEncontrados = 0;
    let pagina = 1;
    let hayMasPaginas = true;

    while (hayMasPaginas) {
        console.log(\`Sincronizando página \${pagina}...\`);
        const { sincronizados, noEncontrados } = sincronizarTodasLasFilas(resultado);
        totalSincronizados += sincronizados;
        totalNoEncontrados += noEncontrados;

        await esperar(1000);

        const resultadoPaginacion = clickPaginaAnterior();
        if (resultadoPaginacion === false) {
            hayMasPaginas = false;
            console.log("Última página procesada.");
        } else {
            await esperar(2000);
        }
        pagina++;
    }

    console.log(\`\\nSincronización completada: \${totalSincronizados} coincidencias encontradas en tabla.\`);
    return resultado;
}

// ═══════════════════════════════════════════════════════════════════
// FUNCIÓN PRINCIPAL 2: DESEMBARCAR CREWLIST
// ═══════════════════════════════════════════════════════════════════

async function desembarcarCrewlist(defaults = {}) {
    const fecha = defaults.fecha || new Date().toLocaleDateString('es-ES').replace(/\\//g, '.');
    const hora = (defaults.hora ?? '00').toString().padStart(2, '0');
    const minutos = (defaults.minutos ?? '00').toString().padStart(2, '0');

    await ajustarSelectoresPorBarco({ statusTexto: 'BOARD', aplicarFiltro: true });
    limpiarBuscador();

    let ronda = 1;

    while (true) {
        await esperar(2000);

        const filas = document.querySelectorAll('tbody tr');
        if (!filas.length) {
            console.log("No hay más filas para desembarcar.");
            break;
        }

        console.log(\`Desembarcando ronda \${ronda} (\${filas.length} filas visibles)...\`);

        const allCheckbox = document.querySelector('[data-test="allCrewCheckbox"]');
        const btnDeboard = document.getElementById('deboard') ||
            Array.from(document.querySelectorAll('button')).find(b => b.innerText.trim() === 'Deboard');

        if (!allCheckbox || !btnDeboard) {
            console.error("desembarcarCrewlist: no se encontró checkbox global o botón Deboard.");
            break;
        }

        if (!allCheckbox.checked) allCheckbox.click();
        await esperar(500);

        clickEnZonaAngular(btnDeboard);
        await esperar(1200);

        const inputFecha = document.getElementById("date");
        const modalInputs = document.querySelectorAll(".modal-body input");

        if (inputFecha && modalInputs.length >= 3) {
            const eventos = ["input", "change", "blur"];
            inputFecha.value = fecha;
            eventos.forEach(e => inputFecha.dispatchEvent(new Event(e, { bubbles: true })));
            await esperar(600);

            modalInputs[1].value = hora;
            modalInputs[2].value = minutos;
            [modalInputs[1], modalInputs[2]].forEach(input => {
                eventos.forEach(e => input.dispatchEvent(new Event(e, { bubbles: true })));
            });
            await esperar(600);

            const btnConfirmar = document.getElementById("modalAccept") ||
                Array.from(document.querySelectorAll("button")).find(b =>
                    (b.innerText.trim() === "Deboard" && b.closest(".modal"))
                ) ||
                Array.from(document.querySelectorAll("button")).find(b =>
                    b.innerText.trim() === "Deboard" && b.classList.contains("btn-success")
                );

            if (btnConfirmar) {
                clickEnZonaAngular(btnConfirmar);
            } else {
                console.error("desembarcarCrewlist: no se encontró botón confirmar en modal.");
                break;
            }
        } else {
            console.error("desembarcarCrewlist: no se encontró el modal de fecha/hora.");
            break;
        }

        ronda++;
    }

    console.log(\`Desembarque completado (\${ronda - 1} rondas procesadas).\`);
}

// ═══════════════════════════════════════════════════════════════════
// FUNCIÓN PRINCIPAL 3: EMBARCAR CREWLIST
// ═══════════════════════════════════════════════════════════════════

async function embarcarCrewlist(resultado, defaults = {}) {
    if (!resultado?.tripulantes?.length) return;

    const defFecha = defaults.fecha || "28.02.2026";
    const defHora = defaults.hora || "21";
    const defMinutos = defaults.minutos || "30";

    resetearSelectores();
    limpiarBuscador();

    for (let i = 0; i < resultado.tripulantes.length; i++) {
        const t = resultado.tripulantes[i];
        const nombre = t.nombre;
        const documento = t.documento?.trim() || "";
        const fecha = t.fecha || defFecha;
        const hora = t.hora || defHora;
        const minutos = t.minutos || defMinutos;

        console.log(\`[\${i + 1}/\${resultado.tripulants.length}] Embarcando: \${nombre || documento}\`);

        const inputBusqueda = document.getElementById('crewMemberDetails') ||
            document.querySelector('input[placeholder*="surname"], .form-control[type="text"]');
        const btnFilter = document.getElementById('filterButton') ||
            Array.from(document.querySelectorAll("button")).find(b => b.innerText.includes("Filter"));

        if (!inputBusqueda || !btnFilter) {
            console.error("  ✗ No se encontró el buscador o el botón Filter.");
            await esperar(1200);
            continue;
        }

        let filaGanadora = null;

        if (documento) {
            inputBusqueda.value = documento;
            inputBusqueda.dispatchEvent(new Event("input", { bubbles: true }));
            btnFilter.click();
            await esperar(900);
            filaGanadora = Array.from(document.querySelectorAll("tbody tr")).find(fila =>
                fila.innerText.toUpperCase().includes(documento.toUpperCase())
            );
        }

        if (!filaGanadora && nombre?.trim()) {
            const palabras = nombre.toUpperCase().trim().split(/\\s+/).filter(Boolean);
            const terminoBusqueda = palabras.length > 0 ? palabras.reduce((a, b) => a.length >= b.length ? a : b) : "";
            if (terminoBusqueda) {
                inputBusqueda.value = terminoBusqueda;
                inputBusqueda.dispatchEvent(new Event("input", { bubbles: true }));
                btnFilter.click();
                await esperar(900);
                filaGanadora = Array.from(document.querySelectorAll("tbody tr")).find(fila => {
                    const textoFila = fila.innerText.toUpperCase();
                    return palabras.every(p => textoFila.includes(p));
                });
            }
        }

        if (filaGanadora) {
            const checkbox = filaGanadora.querySelector('input[type="checkbox"]');
            if (checkbox && !checkbox.checked) {
                checkbox.click();
                await esperar(500);
            }

            const btnBoard = Array.from(document.querySelectorAll("button")).find(b => b.innerText.trim() === "Board");
            if (btnBoard && !btnBoard.disabled) {
                clickEnZonaAngular(btnBoard);
                await esperar(1200);

                const inputFecha = document.getElementById("date");
                const modalInputs = document.querySelectorAll(".modal-body input");

                if (inputFecha && modalInputs.length >= 3) {
                    const eventos = ["input", "change", "blur"];
                    inputFecha.value = fecha;
                    eventos.forEach(e => inputFecha.dispatchEvent(new Event(e, { bubbles: true })));
                    await esperar(600);

                    modalInputs[1].value = hora;
                    modalInputs[2].value = minutos;
                    [modalInputs[1], modalInputs[2]].forEach(input => {
                        eventos.forEach(e => input.dispatchEvent(new Event(e, { bubbles: true })));
                    });
                    await esperar(600);

                    const btnConfirmar = document.getElementById("modalAccept") ||
                        Array.from(document.querySelectorAll("button")).find(b =>
                            b.innerText.trim() === "Board" && b.closest(".modal")
                        ) ||
                        Array.from(document.querySelectorAll("button")).find(b =>
                            b.innerText.trim() === "Board" && b.classList.contains("btn-success")
                        );

                    if (btnConfirmar) {
                        clickEnZonaAngular(btnConfirmar);
                        console.log(\`  ✓ Embarcado con fecha \${fecha} \${hora}:\${minutos}\`);
                    } else {
                        console.error(\`  ✗ No se encontró botón confirmar en modal.\`);
                    }
                } else {
                    console.error(\`  ✗ No se encontró el modal de fecha/hora.\`);
                }
            } else {
                console.error(\`  ✗ Botón Board no disponible.\`);
            }
        } else {
            console.error(\`  ✗ No se pudo localizar en la tabla: \${nombre} / \${documento}\`);
        }

        await esperar(1200);
    }

    console.log("Embarque completado.");
}

