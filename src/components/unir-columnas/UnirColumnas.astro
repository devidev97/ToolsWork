		function showAlert(message: string) {
			if (alertMessage) alertMessage.textContent = message;
			alertOverlay?.classList.remove('hidden');
			document.body.style.overflow = 'hidden';
		}

		function hideAlert() {
			alertOverlay?.classList.add('hidden');
			document.body.style.overflow = 'auto';
		}

		function showToast(message: string) {
			if (!toast) return;
			toast.textContent = message;
			toast.classList.remove('opacity-0', 'pointer-events-none');
			toast.classList.add('opacity-100');
			setTimeout(() => {
				toast.classList.remove('opacity-100');
				toast.classList.add('opacity-0', 'pointer-events-none');
			}, 3000);
		}

		function processColumns() {
			const textA = textareaA.value.trim();
			const textB = textareaB.value.trim();
			const fechaRaw = fechaInput?.value ?? '';
			const horaRaw = horaInput?.value ?? '';

			if (!textA && !textB) {
				showAlert('Debes rellenar al menos una columna (nombres o documentos)');
				return;
			}

			if (!fechaRaw) {
				showAlert('Debes indicar la fecha');
				return;
			}

			if (!horaRaw) {
				showAlert('Debes indicar la hora');
				return;
			}

			const linesA = textA ? textA.split('\n').map(l => l.trim()).filter(l => l !== '') : [];
			const linesB = textB ? textB.split('\n').map(l => l.trim()).filter(l => l !== '') : [];

			if (linesA.length > 0 && linesB.length > 0 && linesA.length !== linesB.length) {
				showAlert(`Advertencia: Las columnas tienen distinto número de líneas (nombres: ${linesA.length}, documentos: ${linesB.length})`);
			}

			// fecha: YYYY-MM-DD -> DD.MM.YYYY
			const [y, m, d] = fechaRaw.split('-');
			const fecha = `${d}.${m}.${y}`;

			// hora: HH:MM -> hora="HH", minutos="MM"
			const [hora, minutos] = horaRaw.split(':');

			const maxLen = Math.max(linesA.length, linesB.length);
			const tripulantes: Tripulante[] = [];
			for (let i = 0; i < maxLen; i++) {
				tripulantes.push({
					nombre: linesA[i] ?? '',
					documento: linesB[i] ?? '',
					fecha,
					hora,
					minutos
				});
			}

			combinedResult = { tripulantes };

			const objStr = 'const obj = ' + JSON.stringify(combinedResult, null, 2) + ';\n\n';
			if (outputPre) {
				outputPre.textContent = objStr + CODIGO_AUTOMATIZACION;
			}
			if (totalCountSpan) {
				totalCountSpan.textContent = tripulantes.length.toString();
			}

			inputContainer?.classList.add('hidden');
			resultsContainer?.classList.remove('hidden');
		}

		function resetForm() {
			textareaA.value = '';
			textareaB.value = '';
			if (fechaInput) fechaInput.value = '';
			if (horaInput) horaInput.value = '';
			combinedResult = { tripulantes: [] };
			inputContainer?.classList.remove('hidden');
			resultsContainer?.classList.add('hidden');
		}

		function copyToClipboard() {
			if (combinedResult.tripulantes.length === 0) return;
			const text = 'const obj = ' + JSON.stringify(combinedResult, null, 2) + ';\n\n' + CODIGO_AUTOMATIZACION;
			navigator.clipboard.writeText(text).then(() => {
				showToast('Objeto y código copiados al portapapeles');
			}).catch(err => {
				console.error('Error al copiar:', err);
				showAlert('No se pudo copiar');
			});
		}

		actionButton.addEventListener('click', processColumns);
		resetButton.addEventListener('click', resetForm);
		copyJsonButton.addEventListener('click', copyToClipboard);
		alertClose?.addEventListener('click', hideAlert);
		alertOk?.addEventListener('click', hideAlert);
		alertOverlay?.addEventListener('click', (e) => {
			if (e.target === alertOverlay) hideAlert();
		});
	});
</script>
