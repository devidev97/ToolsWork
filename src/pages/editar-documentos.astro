---
import Layout from '../layouts/Layout.astro';
import Header from '../components/shared/Header.astro';
---

<Layout>
	<Header />
	
	<main class="min-h-screen bg-[#f4f7f9] pt-[67px]">
		<div class="container mx-auto px-4 py-8">
			<div class="flex justify-between items-center mb-6">
				<h1 class="text-3xl font-bold text-[#002B45]">Editar Documentos</h1>
				<button
					id="generate-pdf-btn"
					class="bg-green-600 text-white px-6 py-2 rounded-lg hover:bg-green-700 transition-colors font-medium hidden"
				>
					Generar PDF Final
				</button>
			</div>
			
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
				<!-- Panel izquierdo: Archivos subidos -->
				<div class="lg:col-span-1">
					<div class="bg-white rounded-lg shadow-lg p-6 mb-6">
						<h2 class="text-xl font-semibold text-gray-800 mb-4">Subir Archivos</h2>
						
						<div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center mb-4">
							<input
								type="file"
								id="file-input"
								accept=".pdf,.jpg,.jpeg,.png,.gif,.webp"
								multiple
								class="hidden"
							/>
							<label
								for="file-input"
								class="cursor-pointer flex flex-col items-center"
							>
								<svg class="w-12 h-12 text-gray-400 mb-2" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
									<path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
									<polyline points="17 8 12 3 7 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
									<line x1="12" y1="3" x2="12" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								</svg>
								<p class="text-sm text-gray-600">Subir documentos</p>
							</label>
						</div>

						<h3 class="text-lg font-semibold text-gray-800 mb-3">Documentos</h3>
						<div id="files-container" class="space-y-2 max-h-[400px] overflow-y-auto">
							<p class="text-gray-500 text-center py-4 text-sm">No hay documentos subidos</p>
						</div>
					</div>
				</div>

				<!-- Panel central: Área de trabajo -->
				<div class="lg:col-span-2">
					<div class="bg-white rounded-lg shadow-lg p-6">
						<div class="flex justify-between items-center mb-4">
							<h2 class="text-xl font-semibold text-gray-800">Área de Trabajo</h2>
							<button
								id="clear-workspace-btn"
								class="text-red-600 hover:text-red-700 text-sm font-medium hidden"
							>
								Limpiar todo
							</button>
						</div>
						
						<div id="workspace" class="border-2 border-dashed border-gray-300 rounded-lg p-8 min-h-[600px] bg-gray-50">
							<div class="text-center text-gray-500 py-20">
								<svg class="w-16 h-16 mx-auto mb-4 text-gray-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
									<rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/>
									<line x1="9" y1="9" x2="15" y2="9" stroke="currentColor" stroke-width="2"/>
									<line x1="9" y1="15" x2="15" y2="15" stroke="currentColor" stroke-width="2"/>
								</svg>
								<p>Haz clic en "Recortar" de un documento para comenzar</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Modal para recortar documentos -->
		<div id="crop-modal" class="hidden fixed inset-0 bg-black bg-opacity-75 z-50 flex items-center justify-center p-4">
			<div class="bg-white rounded-lg max-w-6xl w-full max-h-[90vh] flex flex-col">
				<div class="flex justify-between items-center p-4 border-b">
					<h3 id="crop-title" class="text-lg font-semibold text-gray-800">Recortar Documento</h3>
					<button
						id="close-crop"
						class="text-gray-500 hover:text-gray-700 transition-colors"
					>
						<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
							<line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
						</svg>
					</button>
				</div>
				<div class="flex-1 overflow-auto p-4">
					<div class="mb-4 flex gap-2 items-center flex-wrap">
						<button id="select-area-btn" class="bg-[#002B45] text-white px-4 py-2 rounded hover:bg-[#001a2e] transition-colors">
							Nueva Selección
						</button>
						<button id="crop-all-btn" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition-colors hidden">
							Recortar Todas las Selecciones
						</button>
						<button id="clear-selections-btn" class="bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition-colors hidden">
							Limpiar Selecciones
						</button>
						<span class="text-sm text-gray-600 ml-auto">Arrastra para seleccionar • Ajusta con las esquinas • Puedes crear múltiples selecciones</span>
					</div>
					<div id="crop-content" class="relative border-2 border-gray-300 rounded-lg overflow-hidden bg-gray-100" style="min-height: 500px;">
						<!-- Contenido se insertará aquí -->
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>

<script>
	// Cargar librerías dinámicamente cuando se necesiten
	let pdfLibLoaded = false;
	let jsPdfLoaded = false;

	interface FileItem {
		id: string;
		file: File;
		preview?: string;
		type: 'image' | 'pdf';
	}

	interface CropArea {
		x: number;
		y: number;
		width: number;
		height: number;
	}

	interface WorkspaceItem {
		id: string;
		sourceId: string;
		imageData: string;
		x: number;
		y: number;
		width: number;
		height: number;
		label?: string;
	}

	interface SelectionItem {
		id: string;
		sourceId: string;
		area: CropArea;
		element: HTMLElement;
	}

	const files: FileItem[] = [];
	const workspaceItems: WorkspaceItem[] = [];
	let currentCropFile: FileItem | null = null;
	let isSelecting = false;
	let selectionStart: { x: number; y: number } | null = null;
	let currentSelections: SelectionItem[] = [];
	let activeSelectionId: string | null = null;

	const fileInput = document.getElementById('file-input') as HTMLInputElement;
	const filesContainer = document.getElementById('files-container');
	const workspace = document.getElementById('workspace');
	const cropModal = document.getElementById('crop-modal');
	const cropContent = document.getElementById('crop-content');
	const generatePdfBtn = document.getElementById('generate-pdf-btn');
	const clearWorkspaceBtn = document.getElementById('clear-workspace-btn');

	function isImageFile(file: File): boolean {
		return file.type.startsWith('image/');
	}

	function isPdfFile(file: File): boolean {
		return file.type === 'application/pdf';
	}

	function createPreview(file: File): Promise<string | null> {
		return new Promise((resolve) => {
			if (isImageFile(file)) {
				const reader = new FileReader();
				reader.onload = (e) => resolve(e.target?.result as string || null);
				reader.onerror = () => resolve(null);
				reader.readAsDataURL(file);
			} else {
				resolve(null);
			}
		});
	}

	function formatFileSize(bytes: number): string {
		if (bytes === 0) return '0 Bytes';
		const k = 1024;
		const sizes = ['Bytes', 'KB', 'MB', 'GB'];
		const i = Math.floor(Math.log(bytes) / Math.log(k));
		return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
	}

	function renderFiles() {
		if (!filesContainer) return;

		if (files.length === 0) {
			filesContainer.innerHTML = '<p class="text-gray-500 text-center py-4 text-sm">No hay documentos subidos</p>';
			return;
		}

		filesContainer.innerHTML = files.map(fileItem => {
			return `
				<div class="border border-gray-300 rounded-lg p-3 hover:shadow-md transition-shadow bg-white">
					<div class="mb-2">
						${fileItem.type === 'image' && fileItem.preview 
							? `<img src="${fileItem.preview}" alt="${fileItem.file.name}" class="w-full h-32 object-cover rounded" />`
							: `<div class="w-full h-32 bg-red-100 rounded flex items-center justify-center">
									<svg class="w-12 h-12 text-red-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
										<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" stroke-width="2"/>
										<polyline points="14 2 14 8 20 8" stroke="currentColor" stroke-width="2"/>
									</svg>
								</div>`
						}
					</div>
					<p class="text-xs font-medium text-gray-800 truncate mb-1" title="${fileItem.file.name}">${fileItem.file.name}</p>
					<p class="text-xs text-gray-500 mb-2">${formatFileSize(fileItem.file.size)}</p>
					<button 
						class="w-full bg-[#002B45] text-white px-3 py-1.5 rounded text-xs hover:bg-[#001a2e] transition-colors"
						onclick="openCropEditor('${fileItem.id}')"
					>
						Recortar
					</button>
				</div>
			`;
		}).join('');
	}

	function renderWorkspace() {
		if (!workspace) return;

		if (workspaceItems.length === 0) {
			workspace.innerHTML = `
				<div class="text-center text-gray-500 py-20">
					<svg class="w-16 h-16 mx-auto mb-4 text-gray-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/>
						<line x1="9" y1="9" x2="15" y2="9" stroke="currentColor" stroke-width="2"/>
						<line x1="9" y1="15" x2="15" y2="15" stroke="currentColor" stroke-width="2"/>
					</svg>
					<p>Haz clic en "Recortar" de un documento para comenzar</p>
				</div>
			`;
			generatePdfBtn?.classList.add('hidden');
			clearWorkspaceBtn?.classList.add('hidden');
			return;
		}

		generatePdfBtn?.classList.remove('hidden');
		clearWorkspaceBtn?.classList.remove('hidden');

		workspace.innerHTML = workspaceItems.map((item, index) => {
			return `
				<div 
					class="absolute border-2 border-blue-500 bg-white shadow-lg rounded cursor-move group"
					style="left: ${item.x}px; top: ${item.y}px; width: ${item.width}px; height: ${item.height}px;"
					data-item-id="${item.id}"
				>
					<img src="${item.imageData}" alt="Recorte ${index + 1}" class="w-full h-full object-contain rounded" />
					<div class="absolute top-0 right-0 bg-red-600 text-white w-6 h-6 flex items-center justify-center rounded-bl opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer" onclick="removeWorkspaceItem('${item.id}')">
						×
					</div>
					${item.label ? `<div class="absolute bottom-0 left-0 right-0 bg-black bg-opacity-50 text-white text-xs p-1 text-center">${item.label}</div>` : ''}
				</div>
			`;
		}).join('');

		// Hacer los elementos arrastrables
		makeItemsDraggable();
	}

	function makeItemsDraggable() {
		const items = workspace?.querySelectorAll('[data-item-id]');
		items?.forEach(item => {
			let isDragging = false;
			let startX = 0;
			let startY = 0;
			let initialX = 0;
			let initialY = 0;

			item.addEventListener('mousedown', (e: MouseEvent) => {
				isDragging = true;
				startX = e.clientX;
				startY = e.clientY;
				const rect = (item as HTMLElement).getBoundingClientRect();
				initialX = rect.left;
				initialY = rect.top;
				item.classList.add('z-10');
			});

			document.addEventListener('mousemove', (e: MouseEvent) => {
				if (!isDragging) return;
				const deltaX = e.clientX - startX;
				const deltaY = e.clientY - startY;
				const newX = initialX + deltaX;
				const newY = initialY + deltaY;
				
				const workspaceRect = workspace?.getBoundingClientRect();
				if (workspaceRect) {
					const maxX = workspaceRect.width - (item as HTMLElement).offsetWidth;
					const maxY = workspaceRect.height - (item as HTMLElement).offsetHeight;
					
					(item as HTMLElement).style.left = `${Math.max(0, Math.min(newX - workspaceRect.left, maxX))}px`;
					(item as HTMLElement).style.top = `${Math.max(0, Math.min(newY - workspaceRect.top, maxY))}px`;
				}
			});

			document.addEventListener('mouseup', () => {
				if (isDragging) {
					isDragging = false;
					item.classList.remove('z-10');
					
					// Actualizar posición en el array
					const itemId = (item as HTMLElement).getAttribute('data-item-id');
					const workspaceItem = workspaceItems.find(w => w.id === itemId);
					if (workspaceItem && workspace) {
						const rect = (item as HTMLElement).getBoundingClientRect();
						const workspaceRect = workspace.getBoundingClientRect();
						workspaceItem.x = rect.left - workspaceRect.left;
						workspaceItem.y = rect.top - workspaceRect.top;
					}
				}
			});
		});
	}

	// @ts-ignore
	window.openCropEditor = async function(fileId: string) {
		const fileItem = files.find(f => f.id === fileId);
		if (!fileItem || !cropModal || !cropContent) return;

		currentCropFile = fileItem;
		currentSelections = []; // Limpiar selecciones anteriores
		
		// Limpiar recuadros visuales existentes
		if (cropContent) {
			const existingSelections = cropContent.querySelectorAll('[id^="selection-"]');
			existingSelections.forEach(sel => sel.remove());
		}
		
		const title = document.getElementById('crop-title');
		if (title) title.textContent = `Recortar: ${fileItem.file.name}`;

		if (fileItem.type === 'image' && fileItem.preview) {
			cropContent.innerHTML = `
				<img id="crop-image" src="${fileItem.preview}" class="max-w-full" style="display: block; margin: 0 auto;" />
			`;
			
			// Esperar a que la imagen se cargue
			const img = document.getElementById('crop-image') as HTMLImageElement;
			if (img) {
				img.onload = () => {
					setupImageCrop();
				};
				// Si ya está cargada
				if (img.complete) {
					setupImageCrop();
				}
			}
		} else if (fileItem.type === 'pdf') {
			cropContent.innerHTML = '<p class="text-center py-20">Cargando PDF...</p>';
			await convertPdfToImage(fileItem.file);
		}

		cropModal.classList.remove('hidden');
	};

	// Variables globales para evitar duplicación de listeners
	let currentImageCropHandlers: {
		mouseDownHandler?: (e: MouseEvent) => void;
		mouseMoveHandler?: (e: MouseEvent) => void;
		mouseUpHandler?: () => void;
	} = {};
	let isSetupRunning = false;

	function setupImageCrop() {
		// Prevenir múltiples ejecuciones simultáneas
		if (isSetupRunning) {
			return;
		}
		isSetupRunning = true;

		let cropImage = document.getElementById('crop-image') as HTMLImageElement;
		const selectAreaBtn = document.getElementById('select-area-btn');
		const cropAllBtn = document.getElementById('crop-all-btn');
		const clearSelectionsBtn = document.getElementById('clear-selections-btn');

		if (!cropImage || !cropContent) {
			isSetupRunning = false;
			return;
		}

		// Limpiar handlers anteriores si existen
		if (currentImageCropHandlers.mouseDownHandler && cropImage) {
			cropImage.removeEventListener('mousedown', currentImageCropHandlers.mouseDownHandler);
		}
		if (currentImageCropHandlers.mouseMoveHandler) {
			document.removeEventListener('mousemove', currentImageCropHandlers.mouseMoveHandler);
		}
		if (currentImageCropHandlers.mouseUpHandler) {
			document.removeEventListener('mouseup', currentImageCropHandlers.mouseUpHandler);
		}
		
		// Limpiar referencias
		currentImageCropHandlers = {};

		let isCreatingSelection = false;
		let creatingSelectionBox: HTMLElement | null = null;
		let creatingStart: { x: number; y: number } | null = null;
		let activeSelection: { id: string; element: HTMLElement; isDragging: boolean; isResizing: boolean; resizeHandle: string | null; dragStart: any } | null = null;

		function getSelectionArea(selectionId: string): CropArea | null {
			const box = document.getElementById(selectionId);
			if (!box) return null;
			return {
				x: parseFloat(box.style.left) || 0,
				y: parseFloat(box.style.top) || 0,
				width: parseFloat(box.style.width) || 0,
				height: parseFloat(box.style.height) || 0
			};
		}

		function createSelectionBox(x: number, y: number, width: number, height: number): string {
			if (!cropContent) return '';

			// Si ya hay una selección en proceso de creación, retornar su ID en lugar de crear otra
			if (isCreatingSelection && creatingSelectionBox) {
				return creatingSelectionBox.id;
			}

			const selectionId = 'selection-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9);
			const selectionBox = document.createElement('div');
			selectionBox.id = selectionId;
			selectionBox.className = 'absolute border-2 border-blue-500 bg-blue-200 bg-opacity-20 cursor-move group';
			selectionBox.style.position = 'absolute';
			selectionBox.style.left = `${x}px`;
			selectionBox.style.top = `${y}px`;
			selectionBox.style.width = `${Math.max(10, width)}px`;
			selectionBox.style.height = `${Math.max(10, height)}px`;
			selectionBox.style.zIndex = String(10 + currentSelections.length);
			selectionBox.style.boxSizing = 'border-box';

			// Botón para eliminar esta selección
			const deleteBtn = document.createElement('button');
			deleteBtn.className = 'absolute -top-2 -right-2 bg-red-600 text-white w-6 h-6 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity text-xs font-bold z-20';
			deleteBtn.innerHTML = '×';
			deleteBtn.onclick = (e) => {
				e.stopPropagation();
				selectionBox.remove();
				const index = currentSelections.findIndex(s => s.id === selectionId);
				if (index !== -1) {
					currentSelections.splice(index, 1);
				}
				updateButtonsVisibility();
			};
			selectionBox.appendChild(deleteBtn);

			// Crear handles de redimensionamiento
			const handles = [
				{ class: 'nw-resize', style: 'top: -4px; left: -4px; cursor: nw-resize;' },
				{ class: 'ne-resize', style: 'top: -4px; right: -4px; cursor: ne-resize;' },
				{ class: 'sw-resize', style: 'bottom: -4px; left: -4px; cursor: sw-resize;' },
				{ class: 'se-resize', style: 'bottom: -4px; right: -4px; cursor: se-resize;' },
				{ class: 'n-resize', style: 'top: -4px; left: 50%; transform: translateX(-50%); cursor: n-resize;' },
				{ class: 's-resize', style: 'bottom: -4px; left: 50%; transform: translateX(-50%); cursor: s-resize;' },
				{ class: 'w-resize', style: 'left: -4px; top: 50%; transform: translateY(-50%); cursor: w-resize;' },
				{ class: 'e-resize', style: 'right: -4px; top: 50%; transform: translateY(-50%); cursor: e-resize;' }
			];

			handles.forEach((handle) => {
				const handleEl = document.createElement('div');
				handleEl.className = `resize-handle ${handle.class}`;
				handleEl.style.cssText = `position: absolute; width: 8px; height: 8px; background: #002B45; border: 2px solid white; border-radius: 50%; ${handle.style} z-index: 15;`;
				handleEl.setAttribute('data-handle', handle.class);
				selectionBox.appendChild(handleEl);
			});

			cropContent.appendChild(selectionBox);
			
			// Guardar en el array de selecciones
			const selectionItem: SelectionItem = {
				id: selectionId,
				sourceId: currentCropFile?.id || '',
				area: { x, y, width, height },
				element: selectionBox
			};
			currentSelections.push(selectionItem);

			updateButtonsVisibility();

			// Event listeners para esta selección específica
			setupSelectionInteractions(selectionBox, selectionId);

			return selectionId;
		}

		function setupSelectionInteractions(selectionBox: HTMLElement, selectionId: string) {
			const imgRect = cropImage.getBoundingClientRect();
			const imgWidth = cropImage.offsetWidth;
			const imgHeight = cropImage.offsetHeight;

			selectionBox.addEventListener('mousedown', (e: MouseEvent) => {
				e.stopPropagation();
				const target = e.target as HTMLElement;
				
				if (target.classList.contains('resize-handle')) {
					activeSelection = {
						id: selectionId,
						element: selectionBox,
						isDragging: false,
						isResizing: true,
						resizeHandle: target.getAttribute('data-handle'),
						dragStart: {
							x: parseFloat(selectionBox.style.left) || 0,
							y: parseFloat(selectionBox.style.top) || 0,
							width: parseFloat(selectionBox.style.width) || 0,
							height: parseFloat(selectionBox.style.height) || 0
						}
					};
				} else if (!target.classList.contains('resize-handle') && target !== selectionBox.querySelector('button')) {
					activeSelection = {
						id: selectionId,
						element: selectionBox,
						isDragging: true,
						isResizing: false,
						resizeHandle: null,
						dragStart: {
							x: e.clientX - (parseFloat(selectionBox.style.left) || 0) - imgRect.left,
							y: e.clientY - (parseFloat(selectionBox.style.top) || 0) - imgRect.top
						}
					};
				}
			});
		}

		function updateButtonsVisibility() {
			if (currentSelections.length > 0) {
				cropAllBtn?.classList.remove('hidden');
				clearSelectionsBtn?.classList.remove('hidden');
			} else {
				cropAllBtn?.classList.add('hidden');
				clearSelectionsBtn?.classList.add('hidden');
			}
		}

		// Event listeners globales para mover/redimensionar
		const mouseMoveHandler = (e: MouseEvent) => {
			// Actualizar referencia a la imagen
			const currentCropImage = document.getElementById('crop-image') as HTMLImageElement;
			if (!currentCropImage) return;

			const imgRect = currentCropImage.getBoundingClientRect();
			const imgWidth = currentCropImage.offsetWidth || currentCropImage.naturalWidth || currentCropImage.width;
			const imgHeight = currentCropImage.offsetHeight || currentCropImage.naturalHeight || currentCropImage.height;

			// Manejar creación de nueva selección
			if (isCreatingSelection && creatingSelectionBox && creatingStart) {
				// Verificar que el recuadro aún existe en el DOM
				if (!document.getElementById(creatingSelectionBox.id)) {
					isCreatingSelection = false;
					creatingSelectionBox = null;
					creatingStart = null;
					return;
				}

				const currentX = e.clientX - imgRect.left;
				const currentY = e.clientY - imgRect.top;

				const x = Math.min(creatingStart.x, currentX);
				const y = Math.min(creatingStart.y, currentY);
				const width = Math.abs(currentX - creatingStart.x);
				const height = Math.abs(currentY - creatingStart.y);

				// Asegurar tamaño mínimo visible
				const minSize = 10;
				const finalWidth = Math.max(minSize, width);
				const finalHeight = Math.max(minSize, height);

				creatingSelectionBox.style.left = `${x}px`;
				creatingSelectionBox.style.top = `${y}px`;
				creatingSelectionBox.style.width = `${finalWidth}px`;
				creatingSelectionBox.style.height = `${finalHeight}px`;

				// Actualizar en el array
				const selIndex = currentSelections.findIndex(s => s.id === creatingSelectionBox!.id);
				if (selIndex !== -1) {
					currentSelections[selIndex].area = { x, y, width: finalWidth, height: finalHeight };
				}
				return;
			}

			// Manejar redimensionamiento/arrastre de selección existente
			if (!activeSelection) return;

			const selectionBox = activeSelection.element;

			if (activeSelection.isResizing && activeSelection.resizeHandle && activeSelection.dragStart) {
				const start = activeSelection.dragStart;
				let newX = start.x;
				let newY = start.y;
				let newWidth = start.width;
				let newHeight = start.height;

				const mouseX = e.clientX - imgRect.left;
				const mouseY = e.clientY - imgRect.top;

				switch (activeSelection.resizeHandle) {
					case 'nw-resize':
						newWidth = start.x + start.width - mouseX;
						newHeight = start.y + start.height - mouseY;
						newX = mouseX;
						newY = mouseY;
						break;
					case 'ne-resize':
						newWidth = mouseX - start.x;
						newHeight = start.y + start.height - mouseY;
						newY = mouseY;
						break;
					case 'sw-resize':
						newWidth = start.x + start.width - mouseX;
						newHeight = mouseY - start.y;
						newX = mouseX;
						break;
					case 'se-resize':
						newWidth = mouseX - start.x;
						newHeight = mouseY - start.y;
						break;
					case 'n-resize':
						newHeight = start.y + start.height - mouseY;
						newY = mouseY;
						break;
					case 's-resize':
						newHeight = mouseY - start.y;
						break;
					case 'w-resize':
						newWidth = start.x + start.width - mouseX;
						newX = mouseX;
						break;
					case 'e-resize':
						newWidth = mouseX - start.x;
						break;
				}

				newX = Math.max(0, Math.min(newX, imgWidth));
				newY = Math.max(0, Math.min(newY, imgHeight));
				newWidth = Math.max(20, Math.min(newWidth, imgWidth - newX));
				newHeight = Math.max(20, Math.min(newHeight, imgHeight - newY));

				selectionBox.style.left = `${newX}px`;
				selectionBox.style.top = `${newY}px`;
				selectionBox.style.width = `${newWidth}px`;
				selectionBox.style.height = `${newHeight}px`;

				// Actualizar en el array
				const selIndex = currentSelections.findIndex(s => s.id === activeSelection!.id);
				if (selIndex !== -1) {
					currentSelections[selIndex].area = { x: newX, y: newY, width: newWidth, height: newHeight };
				}
			} else if (activeSelection.isDragging && activeSelection.dragStart) {
				const newX = Math.max(0, Math.min(e.clientX - imgRect.left - activeSelection.dragStart.x, imgWidth - parseFloat(selectionBox.style.width)));
				const newY = Math.max(0, Math.min(e.clientY - imgRect.top - activeSelection.dragStart.y, imgHeight - parseFloat(selectionBox.style.height)));

				selectionBox.style.left = `${newX}px`;
				selectionBox.style.top = `${newY}px`;

				// Actualizar en el array
				const selIndex = currentSelections.findIndex(s => s.id === activeSelection!.id);
				if (selIndex !== -1) {
					currentSelections[selIndex].area.x = newX;
					currentSelections[selIndex].area.y = newY;
				}
			}
		};

		document.addEventListener('mousemove', mouseMoveHandler);
		currentImageCropHandlers.mouseMoveHandler = mouseMoveHandler;

		const mouseUpHandler = () => {
			if (isCreatingSelection && creatingSelectionBox && creatingStart) {
				const area = getSelectionArea(creatingSelectionBox.id);
				if (area && area.width > 10 && area.height > 10) {
					// Selección válida, actualizar área en el array
					const selIndex = currentSelections.findIndex(s => s.id === creatingSelectionBox!.id);
					if (selIndex !== -1) {
						currentSelections[selIndex].area = area;
					}
					isCreatingSelection = false;
					creatingSelectionBox = null;
					creatingStart = null;
				} else {
					// Selección muy pequeña, eliminarla
					creatingSelectionBox.remove();
					const index = currentSelections.findIndex(s => s.id === creatingSelectionBox!.id);
					if (index !== -1) currentSelections.splice(index, 1);
					isCreatingSelection = false;
					creatingSelectionBox = null;
					creatingStart = null;
					updateButtonsVisibility();
				}
			}
			activeSelection = null;
		};

		// Solo agregar listener si no existe ya
		if (!currentImageCropHandlers.mouseUpHandler) {
			document.addEventListener('mouseup', mouseUpHandler);
			currentImageCropHandlers.mouseUpHandler = mouseUpHandler;
		}

		// Limpiar selecciones anteriores al cargar nueva imagen
		currentSelections = [];

		// Función para inicializar handlers
		const initializeCropHandlers = () => {
			// Actualizar referencia a la imagen
			cropImage = document.getElementById('crop-image') as HTMLImageElement;
			if (!cropImage) return;

			const imgWidth = cropImage.offsetWidth || cropImage.naturalWidth || cropImage.width;
			const imgHeight = cropImage.offsetHeight || cropImage.naturalHeight || cropImage.height;

			// Configurar botón de nueva selección
			const finalSelectAreaBtn = document.getElementById('select-area-btn');
			if (finalSelectAreaBtn) {
				// Remover listener anterior si existe
				const newBtn = finalSelectAreaBtn.cloneNode(true);
				finalSelectAreaBtn.parentNode?.replaceChild(newBtn, finalSelectAreaBtn);
				
				document.getElementById('select-area-btn')?.addEventListener('click', (e) => {
					e.preventDefault();
					e.stopPropagation();
					const initialSize = Math.min(imgWidth, imgHeight) * 0.3;
					const x = (imgWidth - initialSize) / 2;
					const y = (imgHeight - initialSize) / 2;
					createSelectionBox(x, y, initialSize, initialSize);
				});
			}

			// Configurar creación de selección arrastrando
			const mouseDownHandler = (e: MouseEvent) => {
				const target = e.target as HTMLElement;
				// Si se hace clic en una selección existente o sus handles, no crear nueva
				if (target.closest('[id^="selection-"]')) {
					return;
				}

				// Si ya hay una selección en proceso, no crear otra
				if (isCreatingSelection) {
					e.preventDefault();
					e.stopPropagation();
					return;
				}

				e.preventDefault();
				e.stopPropagation();

				const rect = cropImage.getBoundingClientRect();
				const startX = e.clientX - rect.left;
				const startY = e.clientY - rect.top;

				// Crear recuadro inicialmente pequeño pero visible
				const minSize = 5;
				const selectionId = createSelectionBox(startX, startY, minSize, minSize);
				creatingSelectionBox = document.getElementById(selectionId);
				if (creatingSelectionBox) {
					isCreatingSelection = true;
					creatingStart = { x: startX, y: startY };
				}
			};

			// Solo agregar listener si no existe ya
			if (!currentImageCropHandlers.mouseDownHandler) {
				cropImage.addEventListener('mousedown', mouseDownHandler, { once: false, passive: false });
				currentImageCropHandlers.mouseDownHandler = mouseDownHandler;
			}
		};

		// Esperar a que la imagen esté completamente cargada
		if (cropImage.complete && cropImage.naturalWidth > 0) {
			setTimeout(() => {
				initializeCropHandlers();
				isSetupRunning = false;
			}, 100);
		} else {
			cropImage.onload = () => {
				setTimeout(() => {
					initializeCropHandlers();
					isSetupRunning = false;
				}, 100);
			};
		}

		cropAllBtn?.addEventListener('click', async () => {
			if (!currentCropFile || currentSelections.length === 0) return;

			for (const selection of currentSelections) {
				const area = getSelectionArea(selection.id);
				if (area && area.width > 10 && area.height > 10) {
					await addCroppedToWorkspace(currentCropFile, area);
				}
			}

			// Limpiar selecciones después de recortar
			currentSelections.forEach(sel => sel.element.remove());
			currentSelections = [];
			updateButtonsVisibility();
		});

		clearSelectionsBtn?.addEventListener('click', () => {
			currentSelections.forEach(sel => sel.element.remove());
			currentSelections = [];
			updateButtonsVisibility();
		});
	}

	async function convertPdfToImage(file: File) {
		try {
			// Cargar pdf.js desde CDN
			// @ts-ignore
			const script = document.createElement('script');
			script.src = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
			document.head.appendChild(script);

			await new Promise((resolve, reject) => {
				script.onload = resolve;
				script.onerror = reject;
			});

			// @ts-ignore
			const pdfjsLib = window.pdfjsLib || window.pdfjs;
			if (!pdfjsLib) {
				throw new Error('PDF.js no se cargó correctamente');
			}

			// @ts-ignore
			pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

			const arrayBuffer = await file.arrayBuffer();
			
			// @ts-ignore
			const loadingTask = pdfjsLib.getDocument({ data: arrayBuffer });
			const pdf = await loadingTask.promise;
			const page = await pdf.getPage(1);
			
			const viewport = page.getViewport({ scale: 2.0 });
			const canvas = document.createElement('canvas');
			const context = canvas.getContext('2d');
			if (!context) {
				throw new Error('No se pudo obtener contexto del canvas');
			}

			canvas.height = viewport.height;
			canvas.width = viewport.width;

			await page.render({
				canvasContext: context,
				viewport: viewport
			}).promise;

			const imageData = canvas.toDataURL('image/png');
			
			if (cropContent) {
				cropContent.innerHTML = `
					<img id="crop-image" src="${imageData}" class="max-w-full" style="display: block; margin: 0 auto;" />
				`;
				// Esperar a que la imagen se cargue antes de configurar
				const img = document.getElementById('crop-image') as HTMLImageElement;
				if (img) {
					img.onload = () => {
						setupImageCrop();
					};
					// Si ya está cargada
					if (img.complete) {
						setupImageCrop();
					}
				}
			}
		} catch (error) {
			console.error('Error al convertir PDF:', error);
			if (cropContent) {
				cropContent.innerHTML = `
					<div class="text-center py-20">
						<p class="text-red-600 mb-4">Error al cargar el PDF</p>
						<p class="text-sm text-gray-600 mb-2">${error instanceof Error ? error.message : 'Error desconocido'}</p>
						<p class="text-xs text-gray-500">Intenta convertir el PDF a imagen primero o usa un formato de imagen</p>
					</div>
				`;
			}
		}
	}

	async function performCrop(fileItem: FileItem, selection: CropArea): Promise<string> {
		return new Promise<string>((resolve, reject) => {
			if (fileItem.type === 'image' && fileItem.preview) {
				const img = new Image();
				img.onload = () => {
					const canvas = document.createElement('canvas');
					const ctx = canvas.getContext('2d');
					if (!ctx) {
						reject(new Error('No se pudo obtener contexto del canvas'));
						return;
					}

					canvas.width = selection.width;
					canvas.height = selection.height;

					ctx.drawImage(
						img,
						selection.x, selection.y, selection.width, selection.height,
						0, 0, selection.width, selection.height
					);

					resolve(canvas.toDataURL('image/png'));
				};
				img.onerror = () => reject(new Error('Error al cargar la imagen'));
				img.src = fileItem.preview;
			} else {
				reject(new Error('Tipo de archivo no soportado para recorte'));
			}
		});
	}

	async function addCroppedToWorkspace(fileItem: FileItem, selection: CropArea) {
		const croppedData = await performCrop(fileItem, selection);
		
		const workspaceItem: WorkspaceItem = {
			id: Date.now().toString(),
			sourceId: fileItem.id,
			imageData: croppedData,
			x: workspaceItems.length * 20,
			y: workspaceItems.length * 20,
			width: selection.width,
			height: selection.height
		};

		workspaceItems.push(workspaceItem);
		renderWorkspace();

		// Cerrar modal
		cropModal?.classList.add('hidden');
		isSelecting = false;
	}

	// @ts-ignore
	window.removeWorkspaceItem = function(itemId: string) {
		const index = workspaceItems.findIndex(w => w.id === itemId);
		if (index !== -1) {
			workspaceItems.splice(index, 1);
			renderWorkspace();
		}
	};

	async function generateFinalPdf() {
		if (workspaceItems.length === 0) return;

		try {
			// Cargar jsPDF dinámicamente si no está cargado
			if (!jsPdfLoaded) {
				// @ts-ignore
				const jsPdfModule = await import('https://cdn.skypack.dev/jspdf@2.5.2');
				// @ts-ignore
				window.jsPDF = jsPdfModule.jsPDF;
				jsPdfLoaded = true;
			}

			// @ts-ignore
			const { jsPDF } = window;
			const pdf = new jsPDF({
				orientation: 'portrait',
				unit: 'mm',
				format: 'a4'
			});

			const pageWidth = pdf.internal.pageSize.getWidth();
			const pageHeight = pdf.internal.pageSize.getHeight();
			const margin = 10;
			const availableWidth = pageWidth - (margin * 2);
			const availableHeight = pageHeight - (margin * 2);

			let currentY = margin;

			for (const item of workspaceItems) {
				// Convertir píxeles a mm (asumiendo 96 DPI)
				const itemWidthMM = (item.width * 25.4) / 96;
				const itemHeightMM = (item.height * 25.4) / 96;

				// Verificar si necesitamos una nueva página
				if (currentY + itemHeightMM > pageHeight - margin) {
					pdf.addPage();
					currentY = margin;
				}

				// Ajustar tamaño si es muy grande
				let finalWidth = itemWidthMM;
				let finalHeight = itemHeightMM;
				
				if (finalWidth > availableWidth) {
					const ratio = availableWidth / finalWidth;
					finalWidth = availableWidth;
					finalHeight = finalHeight * ratio;
				}

				if (currentY + finalHeight > pageHeight - margin) {
					finalHeight = pageHeight - margin - currentY;
					finalWidth = (finalWidth * finalHeight) / itemHeightMM;
				}

				pdf.addImage(item.imageData, 'PNG', margin, currentY, finalWidth, finalHeight);
				currentY += finalHeight + 5; // 5mm de espacio entre elementos
			}

			pdf.save('documento-combinado.pdf');
		} catch (error) {
			console.error('Error al generar PDF:', error);
			alert('Error al generar el PDF. Por favor, intenta de nuevo.');
		}
	}

	async function addFiles(newFiles: FileList | null) {
		if (!newFiles || newFiles.length === 0) return;

		for (let i = 0; i < newFiles.length; i++) {
			const file = newFiles[i];
			
			if (!isImageFile(file) && !isPdfFile(file)) {
				alert(`El archivo ${file.name} no es un formato válido. Solo se permiten PDF e imágenes.`);
				continue;
			}

			const preview = await createPreview(file);
			const fileItem: FileItem = {
				id: Date.now().toString() + '-' + i,
				file,
				preview: preview || undefined,
				type: isImageFile(file) ? 'image' : 'pdf'
			};

			files.push(fileItem);
		}

		renderFiles();
	}

	// Event listeners
	if (fileInput) {
		fileInput.addEventListener('change', (e) => {
			const target = e.target as HTMLInputElement;
			addFiles(target.files);
			target.value = '';
		});
	}

	if (generatePdfBtn) {
		generatePdfBtn.addEventListener('click', generateFinalPdf);
	}

	if (clearWorkspaceBtn) {
		clearWorkspaceBtn.addEventListener('click', () => {
			if (confirm('¿Estás seguro de que quieres limpiar el área de trabajo?')) {
				workspaceItems.length = 0;
				renderWorkspace();
			}
		});
	}

	const closeCrop = document.getElementById('close-crop');
	if (closeCrop) {
		closeCrop.addEventListener('click', () => {
			cropModal?.classList.add('hidden');
			currentSelections = [];
			isSelecting = false;
			// Limpiar selecciones visuales
			currentSelections.forEach(sel => sel.element.remove());
			currentSelections = [];
		});
	}

	// Hacer el workspace relativo para posicionamiento absoluto
	if (workspace) {
		workspace.style.position = 'relative';
	}
</script>
